  "key_strengths": [
    "Mandatory operationalization requirement — every criterion must be tied to a verifiable chart field or test result",
    "Ambiguity-reduction focus is a rare and valuable protocol design discipline",
    "Edge-case rule handling prevents the most common screening inconsistencies",
    "Explicit prohibition on post-enrollment outcomes being used as eligibility criteria"
  ],
  "recommendations": [
    {
      "priority": "P1",
      "title": "No guidance on handling criteria that require complex multi-field logic",
      "observed_in": [],
      "problem": "Some eligibility criteria require complex Boolean combinations of multiple fields (e.g., 'patients with diabetes OR hypertension AND no prior insulin'). The skill handles simple criteria but the multi-field logic edge case is not explicitly covered.",
      "root_cause": "Operationalization rules focus on single-field anchors.",
      "fix": "Add a multi-condition criteria template: when a criterion requires Boolean combination of two or more fields, specify each field anchor separately with the logical operator explicit."
    },
    {
      "priority": "P2",
      "title": "Time-window specification could be more granular",
      "observed_in": [],
      "problem": "Time windows for eligibility criteria are addressed but the specification of window direction (before/after index date vs absolute calendar date) is not always clearly distinguished.",
      "root_cause": "Time-window rules in SKILL.md focus on presence of timing specification but not the direction reference.",
      "fix": "Add a time-window direction rule: explicitly specify whether the window is relative to index date, admission date, procedure date, or absolute calendar time, as these produce different eligible populations."
    }
  ]
