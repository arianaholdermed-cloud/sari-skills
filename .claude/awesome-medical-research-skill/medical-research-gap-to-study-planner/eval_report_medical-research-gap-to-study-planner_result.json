  "recommendations": [
    {
      "priority": "P1",
      "title": "No structured clarification when gap is insufficiently specific",
      "observed_in": [],
      "problem": "When a user provides a vague gap ('there is limited evidence on X'), the skill proceeds with gap-to-design conversion without clarifying what specific evidence is missing.",
      "root_cause": "Input validation accepts any gap statement without minimum specificity requirement.",
      "fix": "Add a minimum gap specificity check: the gap must specify (1) what evidence exists, (2) what is specifically missing, and (3) why the missing evidence matters. If not, ask these three questions before proceeding."
    },
    {
      "priority": "P2",
      "title": "No explicit guidance on handling gaps that span multiple design pattern categories",
      "observed_in": [],
      "problem": "Some research gaps require elements from multiple gap-to-design patterns (e.g., both causality-upgrade and translation-bridge). The skill's single-pattern selection may miss hybrid cases.",
      "root_cause": "Pattern selection logic assumes one dominant pattern per gap.",
      "fix": "Add a hybrid pattern note: if the gap requires both causal upgrading and translational bridging, design the study to address the causal component first as the primary aim, with translational validation as a secondary aim or separate planned study."
    }
  ]
