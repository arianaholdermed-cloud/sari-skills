  "recommendations": [
    {
      "priority": "P1",
      "title": "No explicit handling of competing translational routes for the same finding",
      "observed_in": [],
      "problem": "When a finding could be translated as either a diagnostic marker or a therapeutic target, the skill sometimes designs a blueprint for both simultaneously rather than recommending one primary route.",
      "root_cause": "Route selection logic exists but does not always enforce single-route prioritization for competing directions.",
      "fix": "Add a route competition resolution: when multiple translational routes compete, apply the primary-plan-recommender logic — select one primary route based on evidence strength, feasibility, and gap analysis, then list alternatives as upgrade paths."
    },
    {
      "priority": "P2",
      "title": "Translational milestone timing guidance is generic",
      "observed_in": [],
      "problem": "Milestone descriptions include time estimates but these are based on field-average timelines rather than the user's specific resource context.",
      "root_cause": "Time estimates not explicitly labeled as field averages requiring feasibility adjustment.",
      "fix": "Add caveat: all time estimates for translational milestones are field-average approximations. Users should adjust based on their specific resource context, team size, and institutional infrastructure."
    }
