  "recommendations": [
    {
      "priority": "P1",
      "title": "No explicit handling of scenarios where all routes have equal dependencies",
      "observed_in": [],
      "problem": "When multiple routes have similar dependency profiles, the skill sometimes produces a borderline recommendation without clearly stating the tie-breaking criterion.",
      "root_cause": "Comparison framework covers most cases but does not define a tie-breaking rule.",
      "fix": "Add a tie-breaking protocol: when two routes have similar dependency and evidence profiles, prefer the route with (1) shorter time-to-first-result, then (2) lower resource requirement, then (3) higher publication precedent. State the tie-breaking criterion explicitly."
    },
    {
      "priority": "P2",
      "title": "Recommended plan scope sometimes drifts toward full protocol writing",
      "observed_in": [],
      "problem": "The primary plan recommendation occasionally includes detailed methods guidance that goes beyond plan comparison and selection.",
      "root_cause": "Boundary between plan recommendation and protocol drafting is not explicitly enforced.",
      "fix": "Add a scope enforcement reminder: 'This skill recommends which plan to choose, not how to execute it. Detailed methods, statistical models, and SOPs should be handed off to a protocol design skill.'"
